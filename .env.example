# ─── Base de datos (TiDB Cloud) ───────────────────────────────
DB_HOST=gateway01.ap-southeast-1.prod.aws.tidbcloud.com
DB_PORT=4000
DB_USER=tu_usuario.root
DB_PASS=tu_password_aqui
DB_NAME=canchas_db

# ─── JWT ──────────────────────────────────────────────────────
# Generar con: openssl rand -hex 32
JWT_SECRET=reemplaza_esto_con_un_secret_de_32_caracteres_minimo

# ─── Email (Brevo) ────────────────────────────────────────────
# Obtener en https://www.brevo.com → SMTP & API → API Keys
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Pasarela de pago Flow (pagos y reembolsos en línea) ──────
# Obtener en https://www.flow.cl → Desarrolladores → API Keys
FLOW_API_KEY=XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
FLOW_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FLOW_API_URL=https://www.flow.cl/api
FLOW_URL_CONFIRMACION=https://tu-backend.onrender.com/api/pagos/flow/confirmar
FLOW_URL_RETORNO=https://tu-frontend.onrender.com/reservar.html

# ─── CORS ─────────────────────────────────────────────────────
# En desarrollo local:
FRONTEND_URL=http://localhost:5500
# En producción (cambiar en Render dashboard):
# FRONTEND_URL=https://tu-frontend.onrender.com

# ─── Servidor ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
